{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agnes-agent",
  "version": "0.1.0",
  "identifier": "com.agnes.agent",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm build:sidecar"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "agnes-agent",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": false,
        "fullscreen": false
      },
      {
        "label": "quick",
        "title": "快速问答",
        "url": "index.html?window=quick",
        "create": false,
        "width": 560,
        "height": 430,
        "minWidth": 420,
        "minHeight": 320,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "fullscreen": false,
        "visible": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/reading-books/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/agentd",
      "binaries/document-parserd"
    ],
    "icon": [
      "icons/icon.png"
    ]
  }
}
