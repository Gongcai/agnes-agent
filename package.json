{
  "name": "agnes-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "build:pdf-package": "node scripts/build-pdf-model-package.mjs",
    "preview": "vite preview",
    "test": "vitest run src",
    "test:watch": "vitest src",
    "sync:dev": "pnpm --filter @agnes/sync-api dev",
    "sync:test": "pnpm --filter @agnes/sync-api test",
    "sync:typecheck": "pnpm --filter @agnes/sync-api typecheck",
    "tauri": "GDK_BACKEND=x11 WEBKIT_DISABLE_DMABUF_RENDERER=1 tauri"
  },
  "dependencies": {
    "@fullcalendar/core": "6.1.21",
    "@fullcalendar/daygrid": "6.1.21",
    "@fullcalendar/interaction": "6.1.21",
    "@fullcalendar/list": "6.1.21",
    "@fullcalendar/react": "6.1.21",
    "@fullcalendar/timegrid": "6.1.21",
    "@phosphor-icons/react": "2.1.4",
    "@tanstack/react-query": "^5.59.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "epubjs": "^0.3.93",
    "katex": "^0.17.0",
    "lucide-react": "^0.460.0",
    "luxon": "^3.7.2",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/luxon": "^3.7.2",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
