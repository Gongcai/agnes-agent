{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agnes-sync-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-16",
  "workers_dev": true,
  "vars": {
    "AUTH_MODE": "bearer"
  },
  "d1_databases": [
    {
      "binding": "SYNC_DB",
      "database_name": "agnes-sync",
      "database_id": "44283e54-cfec-4d16-8db8-fa572ff8a9ad",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ARTIFACT_OBJECTS",
      "bucket_name": "agnes-blobs"
    }
  ],
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": ["17 * * * *"]
  }
}
