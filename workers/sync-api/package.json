{
  "name": "@agnes/sync-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply agnes-sync --local",
    "db:migrate:remote": "wrangler d1 migrations apply agnes-sync --remote"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@cloudflare/workers-types": "5.20260715.1",
    "@vitest/expect": "4.1.0",
    "@vitest/mocker": "4.1.0",
    "@vitest/pretty-format": "4.1.0",
    "@vitest/runner": "4.1.0",
    "@vitest/snapshot": "4.1.0",
    "@vitest/spy": "4.1.0",
    "@vitest/utils": "4.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "vitest": "4.1.0",
    "wrangler": "^4.111.0"
  }
}
